# Build context hygiene — keep the image lean and free of secrets/local junk.
.git
.github
.pytest_cache
**/__pycache__
**/*.pyc
**/.mypy_cache
**/.ruff_cache

.env
.env.*
!.env.example

data/
media/
backups/
prowlarr-config/
jackett-config/
auto-m4b-config/
backend/static/

# Frontend deps rebuilt in the Node stage
frontend/node_modules/
frontend/dist/
frontend/public/pdfjs/
frontend/android/

# Not required inside the app image
libraforge/
tools/
deploy-dashboard/
docs/
tests/
nginx/
*.md
!README.md

scripts/dev/
library-site-deploy.zip
library-site-deploy.tar.gz
deploy-*.log
*.log
deploy.ps1
deploy-to-pi.ps1
deploy.local.ps1
eb_*.png
