# App
SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=sqlite+aiosqlite:///data/app.db
APP_URL=https://library.example.com

# Host paths mounted into the app container (docker-compose.yml)
# AUDIOBOOK_HOST_DIR=./media/audiobooks
# EBOOK_HOST_DIR=./media/ebooks
# OPENLIBRARY_HOST_DIR=./media/openlibrary
# PUID=1000
# PGID=1000
# TZ=UTC

# Prowlarr
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=your-prowlarr-api-key

# Indexer cache scraper (optional — defaults shown)
# SCRAPER_ENABLED=true
# SCRAPER_INTERVAL_SECONDS=30
# SCRAPER_QUERIES_PER_JOB=8
# SCRAPER_QUERY_DELAY_SECONDS=2
# SCRAPER_PROWLARR_TIMEOUT=120
# SCRAPER_DEBRID_INTERVAL_HOURS=1
# SCRAPER_DEBRID_BATCH_SIZE=300
# SCRAPER_MATCH_BATCH_SIZE=200
# SCRAPER_RSS_EVERY_N_JOBS=1

# AudioBook Bay — RSS-only is the Admin default (Cache → Tuning). Env seed:
# ABB_RSS_ONLY=true
# ABB_AUTHOR_CRAWL_ENABLED=false
# ABB_DEEP_SEARCH_ENABLED=false
# ABB_LIVE_SEARCH_ENABLED=false
# Live Jackett ABB download search stays on even when RSS-only.

# Mullvad WireGuard — HTTP proxy for ABB only (gluetun:8888).
# Jackett/Knaben stay on LAN. Prefer Admin -> Integrations to register WG keys.
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=10.x.x.x/32
# MULLVAD_ACCOUNT_NUMBER=
# MULLVAD_COUNTRY=USA
# ABB_PROXY_URL=http://gluetun:8888

# Real-Debrid  (get from https://real-debrid.com/apitoken)
REAL_DEBRID_API_TOKEN=your-real-debrid-api-token

# Torbox (optional second debrid service — get from https://torbox.app/settings)
# TORBOX_API_TOKEN=your-torbox-api-token

# Audiobookshelf
ABS_URL=http://localhost:13378
ABS_API_KEY=your-audiobookshelf-api-key
ABS_LIBRARY_ID=your-library-id

# Kavita (ebooks / PDF+EPUB reader)
# KAVITA_URL=http://localhost:5000
# KAVITA_API_KEY=your-kavita-api-key
# KAVITA_LIBRARY_ID=0

# Catalog APIs — preferred: Admin → Config (DB). Env is fallback.
# NYT_API_KEY=your-nyt-api-key
# ISBNDB_API_KEY=your-isbndb-rest-key
# HARDCOVER_API_KEY=Bearer_or_raw_token
# GOOGLE_BOOKS_API_KEY=
# AA_ACCOUNT_ID=   # Anna's Archive membership cookie (optional)

# Jackett (usually auto-synced by deploy/install scripts)
# JACKETT_URL=http://audiobook-jackett:9117
# JACKETT_API_KEY=
# FLARESOLVERR_URL=http://flaresolverr:8191

# Push notifications (generate with: python scripts/generate_vapid.py)
# VAPID_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# VAPID_PUBLIC_KEY=base64url...

# Storage
AUDIOBOOK_DIR=/audiobooks
# EBOOK_DIR=/ebooks
