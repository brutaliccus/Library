"""Post-processing for downloaded audiobooks: normalize folder structure."""

import logging
import re
import shutil
from pathlib import Path

logger = logging.getLogger(__name__)

AUDIO_EXTENSIONS = {".mp3", ".m4a", ".m4b", ".ogg", ".opus", ".flac", ".wav", ".wma", ".aac", ".mp4"}
JUNK_FILES = {".nfo", ".txt", ".jpg", ".jpeg", ".png", ".url", ".html", ".htm", ".sfv", ".nzb"}

_LEADING_NUM_RE = re.compile(r"^(\d{1,2})\s*[-._)\s]")
_BOOK_TITLE_RE = re.compile(
    r"^(.+?)\s*[-_]\s*(\d{1,2})\s*[-_]\s*(.+)$"
)


def _is_audio(path: Path) -> bool:
    return path.is_file() and path.suffix.lower() in AUDIO_EXTENSIONS


def _count_audio_files(directory: Path) -> int:
    return sum(1 for f in directory.rglob("*") if _is_audio(f))


def _flatten_single_child(directory: Path) -> None:
    """If a directory contains only one subdirectory (and no audio files),
    promote the child's contents up and remove the empty child."""
    if not directory.exists():
        return
    items = list(directory.iterdir())
    subdirs = [d for d in items if d.is_dir()]
    audio_files = [f for f in items if _is_audio(f)]

    if len(subdirs) == 1 and not audio_files:
        child = subdirs[0]
        logger.info(f"Flattening single child: {child.name} -> {directory.name}")
        for item in child.iterdir():
            dest = directory / item.name
            if dest.exists():
                dest = directory / f"{child.name} - {item.name}"
            shutil.move(str(item), str(dest))
        child.rmdir()
        _flatten_single_child(directory)


def _detect_book_dirs(directory: Path) -> list[Path]:
    """Return subdirectories that look like individual book folders."""
    return [d for d in sorted(directory.iterdir()) if d.is_dir() and _count_audio_files(d) > 0]


def _extract_book_key(filename: str) -> str:
    """Extract a book identity key from a filename like
    'White Trash Zombie 01 - My Life as a White Trash Zombie.mp3'.
    Returns the full distinguishing portion so different books get different keys."""
    stem = Path(filename).stem.strip()
    stem_clean = re.sub(r"\(.*?\)|\[.*?\]", "", stem).strip()

    m = _BOOK_TITLE_RE.match(stem_clean)
    if m:
        return f"{m.group(1).strip()} {m.group(2)} - {m.group(3).strip()}"

    return stem_clean


def _group_loose_audio(directory: Path) -> dict[str, list[Path]]:
    """Group loose audio files at the top level by detected book identity.

    Each file whose name matches 'Series NN - Title' gets its own group.
    Files following a pure chapter pattern (01 - Chapter 1, 02 - ...) stay together.
    """
    loose = sorted(f for f in directory.iterdir() if _is_audio(f))
    if not loose:
        return {}

    if len(loose) == 1:
        return {_extract_book_key(loose[0].name): loose}

    chapter_like = all(_LEADING_NUM_RE.match(f.stem) for f in loose)

    keys = [_extract_book_key(f.name) for f in loose]
    unique_keys = set(keys)

    if chapter_like and len(unique_keys) <= 1:
        return {"_chapters": loose}

    if len(unique_keys) == 1:
        return {"_chapters": loose}

    groups: dict[str, list[Path]] = {}
    for f, key in zip(loose, keys):
        groups.setdefault(key, []).append(f)

    return groups


def _sanitize(name: str) -> str:
    name = re.sub(r'[<>:"/\\|?*]', "", name)
    return name.strip(". ") or "Unknown"


def _split_mixed_dir(directory: Path, author: str, base_dir: Path) -> list[Path]:
    """Split a directory that contains BOTH loose audio files AND subdirectories
    with audio into separate per-book folders under base_dir/author/."""
    book_dirs = _detect_book_dirs(directory)
    loose_groups = _group_loose_audio(directory)
    result: list[Path] = []

    for bd in book_dirs:
        _flatten_single_child(bd)
        new_name = _sanitize(bd.name)
        final_dir = base_dir / _sanitize(author) / new_name
        if final_dir != bd:
            final_dir.mkdir(parents=True, exist_ok=True)
            for item in bd.iterdir():
                shutil.move(str(item), str(final_dir / item.name))
            try:
                bd.rmdir()
            except OSError:
                pass
        result.append(final_dir)

    for group_name, files in loose_groups.items():
        if group_name == "_chapters":
            continue
        dir_name = _sanitize(group_name)
        group_dir = base_dir / _sanitize(author) / dir_name
        group_dir.mkdir(parents=True, exist_ok=True)
        for f in files:
            if f.parent != group_dir:
                shutil.move(str(f), str(group_dir / f.name))
        result.append(group_dir)

    remaining_loose = [f for f in directory.iterdir() if _is_audio(f)]
    if remaining_loose and not result:
        result.append(directory)
    elif remaining_loose:
        fallback_dir = base_dir / _sanitize(author) / _sanitize(directory.name)
        fallback_dir.mkdir(parents=True, exist_ok=True)
        for f in remaining_loose:
            if f.parent != fallback_dir:
                shutil.move(str(f), str(fallback_dir / f.name))
        result.append(fallback_dir)

    return result


async def normalize_audiobook_dir(dest_dir: Path, author: str, book_title: str) -> list[Path]:
    """Normalize an audiobook download directory. Returns list of final book directories.

    Handles:
    - Flattening unnecessary nesting
    - Splitting collection downloads into individual book directories
    - Recursively splitting nested batch directories (e.g. 'Books 01-04' containing 4 books)
    - Grouping loose chapter files
    """
    if not dest_dir.exists():
        logger.warning(f"Post-process: directory does not exist: {dest_dir}")
        return [dest_dir]

    logger.info(f"Post-processing audiobook: {dest_dir}")
    base_dir = dest_dir.parent.parent  # e.g. /audiobooks (up from Author/Title/)

    _flatten_single_child(dest_dir)

    book_dirs = _detect_book_dirs(dest_dir)
    loose_groups = _group_loose_audio(dest_dir)
    top_audio = [f for f in dest_dir.iterdir() if _is_audio(f)]

    result_dirs: list[Path] = []

    if not book_dirs and not top_audio:
        logger.info(f"Post-process: no audio files found in {dest_dir}")
        return [dest_dir]

    is_collection = (
        len(book_dirs) > 1
        or (len(book_dirs) >= 1 and len(loose_groups) > 0)
        or (len(book_dirs) == 0 and len(loose_groups) > 1)
    )

    if is_collection:
        logger.info(f"Detected collection: {len(book_dirs)} book dirs + {len(loose_groups)} loose groups")

        for bd in book_dirs:
            _flatten_single_child(bd)
            inner_book_dirs = _detect_book_dirs(bd)
            inner_loose = _group_loose_audio(bd)
            inner_top = [f for f in bd.iterdir() if _is_audio(f)]

            is_nested_collection = (
                (len(inner_book_dirs) > 1)
                or (len(inner_book_dirs) >= 1 and len(inner_loose) > 0)
                or (len(inner_top) > 0 and len(inner_book_dirs) > 0)
                or (len(inner_loose) > 1)
            )

            if is_nested_collection:
                logger.info(f"Nested collection in {bd.name}: {len(inner_book_dirs)} dirs + {len(inner_loose)} loose groups")
                split_results = _split_mixed_dir(bd, author, base_dir)
                result_dirs.extend(split_results)
            else:
                new_name = _sanitize(bd.name)
                final_dir = base_dir / _sanitize(author) / new_name
                if final_dir != bd and final_dir != dest_dir:
                    final_dir.mkdir(parents=True, exist_ok=True)
                    for item in bd.iterdir():
                        shutil.move(str(item), str(final_dir / item.name))
                    try:
                        bd.rmdir()
                    except OSError:
                        pass
                    result_dirs.append(final_dir)
                else:
                    result_dirs.append(bd)

        for group_name, files in loose_groups.items():
            if group_name == "_chapters":
                group_name = book_title
            dir_name = _sanitize(group_name)
            group_dir = base_dir / _sanitize(author) / dir_name
            group_dir.mkdir(parents=True, exist_ok=True)
            for f in files:
                dest = group_dir / f.name
                if f.parent != group_dir:
                    shutil.move(str(f), str(dest))
            result_dirs.append(group_dir)

        _cleanup_empty(dest_dir)

    elif len(book_dirs) == 1 and not top_audio:
        single = book_dirs[0]
        _flatten_single_child(single)
        if single != dest_dir:
            for item in single.iterdir():
                shutil.move(str(item), str(dest_dir / item.name))
            try:
                single.rmdir()
            except OSError:
                pass
        result_dirs.append(dest_dir)

    elif top_audio and not book_dirs:
        if len(loose_groups) <= 1:
            result_dirs.append(dest_dir)
        else:
            for group_name, files in loose_groups.items():
                if group_name == "_chapters":
                    result_dirs.append(dest_dir)
                    continue
                dir_name = _sanitize(group_name)
                group_dir = base_dir / _sanitize(author) / dir_name
                group_dir.mkdir(parents=True, exist_ok=True)
                for f in files:
                    if f.parent != group_dir:
                        shutil.move(str(f), str(group_dir / f.name))
                result_dirs.append(group_dir)
            _cleanup_empty(dest_dir)
    else:
        result_dirs.append(dest_dir)

    for d in result_dirs:
        if d.exists():
            _clean_junk(d)

    logger.info(f"Post-process complete: {len(result_dirs)} book dir(s)")
    return result_dirs


def _cleanup_empty(directory: Path) -> None:
    """Recursively remove empty directories."""
    if not directory.exists():
        return
    for child in list(directory.iterdir()):
        if child.is_dir():
            _cleanup_empty(child)
    if directory.exists() and not any(directory.iterdir()):
        try:
            directory.rmdir()
            logger.info(f"Removed empty directory: {directory}")
        except OSError:
            pass


def _clean_junk(directory: Path) -> None:
    """Remove common junk files that confuse ABS."""
    for f in directory.iterdir():
        if f.is_file() and f.suffix.lower() in JUNK_FILES and f.stem.lower() in (
            "readme", "rarbg", "torrent downloaded from", "downloaded from",
            "www", "url", "source", "info",
        ):
            f.unlink(missing_ok=True)
